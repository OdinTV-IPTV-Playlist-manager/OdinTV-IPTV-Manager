```gitignore
# Media playlists
*.m3u8

# Environment
.env
.env.local
*.env.*

# Logs
*.log

# Dependencies
node_modules/
vendor/

# Build artifacts
dist/
build/
target/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Java
*.class
*.jar
*.war

# C/C++
*.o
*.obj
*.a
*.so
*.dll
*.exe

# Compression
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst

# Editors
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Coverage
coverage/
htmlcov/
.coverage

# Gradle
.gradle/

# MyPy
.mypy_cache/

# PyTest
.pytest_cache/
```